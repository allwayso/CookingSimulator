{
  "recipeId": "tomato_egg",
  "name": "番茄炒蛋",
  "description": "先炒鸡蛋盛出，再炒番茄出沙，最后混合调味出锅。",
  "ingredients": ["番茄", "鸡蛋"],
  "seasonings": ["盐"],
  "steps": [
